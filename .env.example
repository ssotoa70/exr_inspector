# exr-inspector Configuration
# Copy to .env and fill in your VAST cluster details
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your values
#   ./deploy.sh --config .env

##############################################################################
# S3 Source Bucket Access (Required)
##############################################################################

# VAST S3 data VIP endpoint
S3_ENDPOINT="http://${DATA_VIP}"

# S3 access credentials (for downloading EXR files)
S3_ACCESS_KEY=""
S3_SECRET_KEY=""

# S3 bucket name for EXR file ingestion (trigger source)
S3_BUCKET=""

##############################################################################
# VAST DataBase Configuration (Required for persistence)
##############################################################################

# VAST DataBase endpoint (defaults to S3_ENDPOINT if not set)
# VAST_DB_ENDPOINT="http://${DB_VIP}"

# VAST DataBase credentials (defaults to S3 credentials if not set)
# VAST_DB_ACCESS_KEY=""
# VAST_DB_SECRET_KEY=""

# Database bucket (must be Database-enabled view with S3,DATABASE protocols)
VAST_DB_BUCKET=""

# Schema name (auto-created on first run)
VAST_DB_SCHEMA="exr_metadata"

##############################################################################
# VAST Cluster / vastde CLI Configuration
##############################################################################

# VAST Management Service URL
VAST_CLUSTER_URL=""

# VAST API credentials
VAST_TENANT_NAME="default"
VAST_USERNAME=""
VAST_PASSWORD=""

##############################################################################
# Container Registry
##############################################################################

# Registry URL (e.g., your-registry.example.com:5000)
REGISTRY_URL=""
REGISTRY_USERNAME=""
REGISTRY_PASSWORD=""

# Image name and tag
IMAGE_REPOSITORY="exr-inspector"
IMAGE_TAG="latest"
